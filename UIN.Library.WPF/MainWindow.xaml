<Window x:Class="UIN.Library.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library App"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen">
        
    <StackPanel Margin="20">

        <Label Content="Username"/>
        <TextBox x:Name="UsernameBox" Margin="0,5,0,10"/>

        <Label Content="Role (admin/editor/reader)"/>
        <TextBox x:Name="RoleBox" Margin="0,5,0,10"/>

        <Button Content="Login" Click="Login_Click" Margin="0,10,0,10"/>

        <Button Content="Load Books" Click="LoadBooks_Click"/>

        <ListBox x:Name="BooksList" Margin="0,10,0,0"/>

        <Button Content="Logout" Click="Logout_Click" Margin="0,10,0,10"/>

    </StackPanel>

</Window>